---
layout: base.njk
section: essays
pagination:
  data: subjects
  size: 1
  alias: subject
permalink: "/subjects/{{ subject.slug }}/"
eleventyComputed:
  title: "{{ subject.title }}"
---
<div class="page">
  <div class="titlepage" style="padding-bottom:0;">
    <h1 class="volume" style="font-size:46px;">{{ subject.title }}</h1>
    <div class="ruler"><span class="motif">&#10086;</span></div>
  </div>
  <div style="height:24px;"></div>
  <div class="essays">
    {% set matches = collections.writing | bySubject(subject.slug) %}
    {% if matches.length %}
      {% for p in matches %}
      <div class="entry">
        <p class="cat">{{ p.data.category }}</p>
        <h3><a href="{{ p.url }}">{{ p.data.title }}</a></h3>
        <p class="date">{{ p.date | readableDate }}</p>
        <p class="dek">{{ p.data.dek }}</p>
      </div>
      {% endfor %}
    {% else %}
      <p class="introduction">Nothing here yet. Essays on this subject will appear as they are written.</p>
    {% endif %}
  </div>
</div>
