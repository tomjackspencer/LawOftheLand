<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
<meta name="description" content="{{ description or site.byline }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body class="{{ bodyClass }}">

<div class="topband">
  <div class="navbar">
    <button class="menu-toggle" aria-expanded="false" aria-controls="primary-nav" onclick="toggleMenu(this)">Menu</button>
    <nav class="site" id="primary-nav">
      <div class="navitem">
        <a href="/essays/" class="{% if section == 'essays' %}current{% endif %}">Essays <span class="caret">&#9662;</span></a>
        <div class="dropdown">
          {% for s in subjects %}<a href="/subjects/{{ s.slug }}/">{{ s.title }}</a>{% endfor %}
        </div>
      </div>
      <div class="navitem">
        <a href="/case-notes/" class="{% if section == 'casenotes' %}current{% endif %}">Case&nbsp;Notes <span class="caret">&#9662;</span></a>
        <div class="dropdown">
          {% for s in subjects %}<a href="/subjects/{{ s.slug }}/">{{ s.title }}</a>{% endfor %}
        </div>
      </div>
      <div class="navitem">
        <a href="/institutes/" class="{% if section == 'institutes' %}current{% endif %}">Institutes <span class="caret">&#9662;</span></a>
        <div class="dropdown">
          {% for n in collections.institutes %}<a href="{{ n.url }}">{{ n.data.title }}</a>{% endfor %}
        </div>
      </div>
      <div class="navitem"><a href="/about/" class="{% if section == 'about' %}current{% endif %}">About</a></div>
    </nav>
  </div>
</div>

{{ content | safe }}

<footer class="site">
  <div class="inner">
    <div class="footrule"></div>
    <p class="subscribe">{{ site.footerNote }} <a href="/about/">Subscribe</a>.</p>
    <p class="disclaimer">{{ site.disclaimer }} &copy; {% year %}.</p>
  </div>
</footer>

<script>
  function toggleMenu(btn){
    var nav=document.getElementById('primary-nav');
    var open=nav.classList.toggle('open');
    btn.setAttribute('aria-expanded', open);
  }
  // On mobile, tapping a nav item with a submenu expands it instead of navigating away
  document.querySelectorAll('.navitem > a .caret').forEach(function(c){
    var link=c.closest('a');
    link.addEventListener('click', function(e){
      if(window.matchMedia('(max-width:640px)').matches){
        e.preventDefault();
        link.closest('.navitem').classList.toggle('expanded');
      }
    });
  });
</script>
</body>
</html>
