---
layout: base.njk
section: casenotes
permalink: /case-notes/
title: Case Notes
---
<div class="page">
  <div class="titlepage" style="padding-bottom:0;"><h1 class="volume" style="font-size:50px;">Case Notes</h1><div class="ruler"><span class="motif">&#10086;</span></div></div>
  <div style="height:24px;"></div>
  <div class="essays">
    {% for p in collections.casenotes %}
    <div class="entry">
      <p class="cat">{{ p.data.category }}</p>
      <h3><a href="{{ p.url }}">{{ p.data.title }}</a></h3>
      <p class="date">{{ p.date | readableDate }}</p>
      <p class="dek">{{ p.data.dek }}</p>
    </div>
    {% endfor %}
  </div>
</div>
