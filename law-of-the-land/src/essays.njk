---
layout: base.njk
section: essays
permalink: /essays/
title: Essays
---
<div class="page">
  <div class="titlepage" style="padding-bottom:0;"><h1 class="volume" style="font-size:50px;">Essays</h1><div class="ruler"><span class="motif">&#10086;</span></div></div>
  <div style="height:24px;"></div>
  <div class="essays">
    {% for p in collections.essays %}
    <div class="entry">
      <p class="cat">{{ p.data.category }}</p>
      <h3><a href="{{ p.url }}">{{ p.data.title }}</a></h3>
      <p class="date">{{ p.date | readableDate }}</p>
      <p class="dek">{{ p.data.dek }}</p>
    </div>
    {% endfor %}
  </div>
</div>
